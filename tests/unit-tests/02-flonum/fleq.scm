(include "#.scm")

(test-eqv #f (##fl= +inf.0 -inf.0))
(test-eqv #t (##fl= -0.0 0.0))
(test-eqv #t (##fl= 0.0))
(test-eqv #f (##fl= 0.0 1.5))
(test-eqv #f (##fl= 2.0 -1.5 0.5))
(test-eqv #f (##fl= -1.0 1.0 1.0))
(test-eqv #t (##fl= 1.0 1.0 1.0))

(test-eqv #f (fl= +inf.0 -inf.0))
(test-eqv #t (fl= -0.0 0.0))
(test-eqv #t (fl= 0.0))
(test-eqv #f (fl= 0.0 1.5))
(test-eqv #f (fl= 2.0 -1.5 0.5))
(test-eqv #f (fl= -1.0 1.0 1.0))
(test-eqv #t (fl= 1.0 1.0 1.0))

(test-error-tail type-exception? (fl= 1 1.0))
(test-error-tail type-exception? (fl= 1.0 1))
(test-error-tail type-exception? (fl= 1.0 1.0 1))
(test-error-tail type-exception? (fl= 1/2))
