(include "#.scm")

(test-eqv  0.1875 (##fl*  0.25  0.75))
(test-eqv -0.0625 (##fl*  0.25 -0.25))
(test-eqv -0.1875 (##fl*  0.25 -0.75))
(test-eqv -0.1875 (##fl* -0.25  0.75))

(test-eqv 1.0    (##fl*))
(test-eqv 0.25   (##fl* 0.25))
(test-eqv 0.5    (##fl* 0.25 2.0))
(test-eqv 0.25   (##fl* 0.25 2.0 0.5))
(test-eqv 0.1875 (##fl* 0.25 2.0 0.5 0.75))

(test-eqv  0.1875 (fl*  0.25  0.75))
(test-eqv -0.0625 (fl*  0.25 -0.25))
(test-eqv -0.1875 (fl*  0.25 -0.75))
(test-eqv -0.1875 (fl* -0.25  0.75))

(test-eqv 1.0    (fl*))
(test-eqv 0.25   (fl* 0.25))
(test-eqv 0.5    (fl* 0.25 2.0))
(test-eqv 0.25   (fl* 0.25 2.0 0.5))
(test-eqv 0.1875 (fl* 0.25 2.0 0.5 0.75))

(test-error-tail type-exception? (fl* 1))
(test-error-tail type-exception? (fl* 1 4.2))
(test-error-tail type-exception? (fl* 0.5 9))
(test-error-tail type-exception? (fl* 9 0.5 4.2))
(test-error-tail type-exception? (fl* 0.5 9 4.2))
(test-error-tail type-exception? (fl* 0.5 4.2 9))
