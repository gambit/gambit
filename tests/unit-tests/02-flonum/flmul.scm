(include "#.scm")

(test-eqv .1875 (##fl* .25 .75))
(test-eqv -.0625 (##fl* .25 -.25))
(test-eqv -.1875 (##fl* .25 -.75))
(test-eqv -.1875 (##fl* -.25 .75))

(test-eqv 1. (##fl*))
(test-eqv .25 (##fl* .25))
(test-eqv .5 (##fl* .25 2.))
(test-eqv .25 (##fl* .25 2. .5))
(test-eqv .1875 (##fl* .25 2. .5 .75))

(test-eqv .1875 (fl* .25 .75))
(test-eqv -.0625 (fl* .25 -.25))
(test-eqv -.1875 (fl* .25 -.75))
(test-eqv -.1875 (fl* -.25 .75))

(test-eqv 1. (fl*))
(test-eqv .25 (fl* .25))
(test-eqv .5 (fl* .25 2.))
(test-eqv .25 (fl* .25 2. .5))
(test-eqv .1875 (fl* .25 2. .5 .75))

(test-error-tail type-exception? (fl* 1))
(test-error-tail type-exception? (fl* 1 4.2))
(test-error-tail type-exception? (fl* .5 9))
(test-error-tail type-exception? (fl* 9 .5 4.2))
(test-error-tail type-exception? (fl* .5 9 4.2))
(test-error-tail type-exception? (fl* .5 4.2 9))
