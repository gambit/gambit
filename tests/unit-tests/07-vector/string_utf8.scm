(include "#.scm")

(test-equal '#u8(65 66 67) (string->utf8 "ABC"))
(test-equal '#u8(65 66 67) (string->utf8 "ABC" 0))
(test-equal '#u8() (string->utf8 "ABC" 3))
(test-equal '#u8(66) (string->utf8 "ABC" 1 2))
(test-equal '#u8(66 67) (string->utf8 "ABC" 1 3))
(test-equal '#u8() (string->utf8 "ABC" 3 3))

#;(test-equal '#u8() (string->utf8 ""))
(test-equal '#u8(#x00) (string->utf8 "\x0;"))
(test-equal '#u8(#x7F) (string->utf8 "\x7f;"))
(test-equal '#u8(#xC2 #x80) (string->utf8 "\x80;"))
(test-equal '#u8(#xC2 #xBF) (string->utf8 "\xbf;"))
(test-equal '#u8(#xC3 #xBF) (string->utf8 "\xff;"))

(define-macro (if-max-char-code-greater-than n code-as-string)
  (if (> (##max-char-code) n)
      `(begin ,@(with-input-from-string code-as-string read-all))
      `(begin)))

(if-max-char-code-greater-than 255 #<<end-of-at-least-2-byte-chars
(test-equal '#u8(#xDF #x80) (string->utf8 "\x7c0;"))
(test-equal '#u8(#xDF #xBF) (string->utf8 "\x7ff;"))
(test-equal '#u8(#xE0 #xA0 #x80) (string->utf8 "\x800;"))
(test-equal '#u8(#xE0 #xA0 #xBF) (string->utf8 "\x83f;"))
(test-equal '#u8(#xE0 #xBF #x80) (string->utf8 "\xfc0;"))
(test-equal '#u8(#xE0 #xBF #xBF) (string->utf8 "\xfff;"))
(test-equal '#u8(#xE1 #x80 #x80) (string->utf8 "\x1000;"))
(test-equal '#u8(#xE1 #x80 #xBF) (string->utf8 "\x103f;"))
(test-equal '#u8(#xE1 #xBF #x80) (string->utf8 "\x1fc0;"))
(test-equal '#u8(#xE1 #xBF #xBF) (string->utf8 "\x1fff;"))
(test-equal '#u8(#xEF #x80 #x80) (string->utf8 "\xf000;"))
(test-equal '#u8(#xEF #x80 #xBF) (string->utf8 "\xf03f;"))
(test-equal '#u8(#xEF #xBF #x80) (string->utf8 "\xffc0;"))
(test-equal '#u8(#xEF #xBF #xBF) (string->utf8 "\xffff;"))
