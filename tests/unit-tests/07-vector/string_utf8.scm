(test-error-tail type-exception? (string->utf8 #f))
(test-error-tail type-exception? (string->utf8 "ABC" #f))
(test-error-tail type-exception? (string->utf8 "ABC" 0 #f))

(test-error-tail range-exception? (string->utf8 "ABC" -1))
(test-error-tail range-exception? (string->utf8 "ABC" 4))
(test-error-tail range-exception? (string->utf8 "ABC" 0 4))

(test-error-tail wrong-number-of-arguments-exception? (string->utf8))
(test-error-tail wrong-number-of-arguments-exception? (string->utf8 "" 0 0 0))
