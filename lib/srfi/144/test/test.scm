;; Test procedures for (flsin), (flcos), and (fltan)
(define (test-fltrigonometry)
  (let ((x 1.0))
    (test-approx-eq (flsin x) (sin x) )
    (test-approx-eq (flcos x) (cos x) )
    (test-approx-eq (fltan x) (tan x) )))

;; Test procedures for (flasin), (flacos), and (flatan)
(define (test-flinv-trigonometry)
  (let ((x 1.0))
    (test-approx-eq (flasin x) (asin x) )
    (test-approx-eq (flacos x) (acos x) )
    (test-approx-eq (flatan x) (atan x) )))

;; Test procedures for (flsinh), (flcosh), and (fltanh)
(define (test-flhyperbolic)
  (let ((x 1.0))
    (test-approx-eq (flsinh x) (sinh x) )
    (test-approx-eq (flcosh x) (cosh x) )
    (test-approx-eq (fltanh x) (tanh x) )))

;; Test procedures for (flasinh), (flacosh), and (flatanh)
(define (test-flinv-hyperbolic)
  (let ((x 1.0))
    (test-approx-eq (flasinh x) (asinh x) )
    (test-approx-eq (flacosh x) (acosh x) )
    (test-approx-eq (flatanh x) (atanh x) )))

;; Test procedures for (flquotient), (flremainder), and (flremquo)
(define (test-flinteger-division)
  (let ((x 5.0)
        (y 2.0))
    (test-approx-eq (flquotient x y) (/ x y) )
    (test-approx-eq (flremainder x y) (remainder x y) )
    (test-equal (receive (a b) (flremquo x y) (list a b)) (list (flquotient x y) (flremainder x y)) )))

;; Test procedures for (flgamma), (flloggamma), and special Bessel and error functions
(define (test-flspecial-functions)
  (let ((x 2.0))
    (test-approx-eq (flgamma x) (gamma x) )
    (test-approx-eq (flloggamma x) (log-gamma x) )
    (test-approx-eq (flfirst-bessel 0 x) (jn 0 x) )
    (test-approx-eq (flsecond-bessel 0 x) (yn 0 x) )
    (test-approx-eq (flerf x) (erf x) )
    (test-approx-eq (flerfc x) (erfc x) )))

;; Run tests
(test-fltrigonometry)
(test-flinv-trigonometry)
(test-flhyperbolic)
(test-flinv-hyperbolic)
(test-flinteger-division)
(test-flspecial-functions)


